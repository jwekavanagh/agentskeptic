{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentskeptic.com/schemas/decision-evidence-bundle-manifest-v2.schema.json",
  "title": "DecisionEvidenceBundleManifestV2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "bundleKind", "producer", "createdAt", "workflowId", "certificate", "materialTruth", "completeness"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "bundleKind": { "const": "decision_evidence" },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "workflowId": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "certificate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relativePath", "sha256"],
      "properties": {
        "relativePath": { "const": "outcome-certificate.json" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "materialTruth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relativePath", "schemaVersion", "sha256"],
      "properties": {
        "relativePath": { "const": "material-truth.json" },
        "schemaVersion": { "const": 2 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "completeness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "artifacts"],
      "properties": {
        "status": { "type": "string", "enum": ["complete", "partial", "invalid"] },
        "artifacts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["a4Present", "a5Present", "a5Required"],
          "properties": {
            "a4Present": { "type": "boolean" },
            "a5Present": { "type": "boolean" },
            "a5Required": { "type": "boolean" }
          }
        }
      }
    }
  }
}
