{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentskeptic.com/schemas/decision-evidence-attestation-v1.schema.json",
  "title": "DecisionEvidenceAttestationV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "statement"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "scopeKind": {
      "type": "string",
      "enum": ["integrator_owned", "drill_or_reproduction", "unspecified"]
    },
    "eventsPath": { "type": "string" },
    "registryPath": { "type": "string" },
    "statement": { "type": "string", "minLength": 1 },
    "author": { "type": "string" }
  }
}
